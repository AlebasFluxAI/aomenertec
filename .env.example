# ==============================================================================
# FLUXAI LARAVEL - CONFIGURACIÓN DE VARIABLES DE ENTORNO
# ==============================================================================
# Este archivo documenta todas las variables de entorno disponibles.
# Copiá este archivo a .env y configurá los valores según tu entorno.
# ==============================================================================

# ------------------------------------------------------------------------------
# APLICACIÓN GENERAL
# ------------------------------------------------------------------------------
APP_NAME=FluxAI
APP_ENV=local
APP_KEY=
# Auto-generado por: php artisan jwt:secret
JWT_SECRET=
APP_DEBUG=true
# URL base de la aplicación web Laravel
# Local: http://localhost
# Producción: https://app.fluxai.solutions
APP_URL=http://localhost

# Patrón de subdominios para rutas multi-tenant
# Local: {subdomain}.localhost (requiere configurar /etc/hosts)
# Producción: {subdomain}.fluxai.solutions
# IMPORTANTE: {subdomain} es un placeholder de Laravel, NO reemplazar
APP_SUBDOMAIN_PATTERN={subdomain}.localhost

# ------------------------------------------------------------------------------
# LOGGING
# ------------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ------------------------------------------------------------------------------
# DOCKER SAIL
# ------------------------------------------------------------------------------
WWWUSER=1000
WWWGROUP=1000
SAIL_XDEBUG_MODE=develop,debug

# ------------------------------------------------------------------------------
# BASE DE DATOS (PostgreSQL)
# ------------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=enertec
DB_USERNAME=sail
DB_PASSWORD=password

# ------------------------------------------------------------------------------
# BROADCASTING, CACHE & SESSIONS
# ------------------------------------------------------------------------------
BROADCAST_DRIVER=redis
CACHE_DRIVER=redis
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=database
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

# ------------------------------------------------------------------------------
# REDIS (Cache & Broadcasting)
# ------------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ------------------------------------------------------------------------------
# MQTT BROKER INTERNO (Recibe datos de medidores)
# ------------------------------------------------------------------------------
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_CLIENT_ID=client_consumer_principal
MQTT_CLEAN_SESSION=false
MQTT_ENABLE_LOGGING=true
MQTT_AUTH_USERNAME=enertec
MQTT_AUTH_PASSWORD=enertec2020**

# ------------------------------------------------------------------------------
# LARAVEL API URL (para scripts Python)
# ------------------------------------------------------------------------------
LARAVEL_API_URL=http://localhost

# ------------------------------------------------------------------------------
# AOM API (URL base de la propia web app)
# ------------------------------------------------------------------------------
# La web app se llama a sí misma para endpoints de configuración IoT
# Local: http://localhost
# Producción: https://app.fluxai.solutions
AOM_API_URL=http://localhost
AOM_API_CONFIG_PATH=/api/v1/config
AOM_API_CLIENTS_PATH=/api/v1/clients

# Password para acceso a endpoints de firmware desde la app móvil
FIRMWARE_API_PASSWORD=123456789

# ------------------------------------------------------------------------------
# VALORES POR DEFECTO PARA NUEVOS CLIENTES
# ------------------------------------------------------------------------------
DEFAULT_MQTT_HOST=3.12.98.178
DEFAULT_MQTT_PORT=1883
DEFAULT_MQTT_USER=enertec
DEFAULT_MQTT_PASSWORD=enertec2020**
DEFAULT_REAL_TIME_LATENCY=30
DEFAULT_STORAGE_LATENCY=1
DEFAULT_BILLING_DAY=1

# ------------------------------------------------------------------------------
# CORREO ELECTRÓNICO
# ------------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@fluxai.local
MAIL_FROM_NAME="${APP_NAME}"

# ------------------------------------------------------------------------------
# AWS S3
# ------------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ------------------------------------------------------------------------------
# PUSHER
# ------------------------------------------------------------------------------
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
