# =============================================================================
# FluxAI Production Environment Configuration
# =============================================================================
# IMPORTANTE: Copia este archivo a .env.production y completa los valores
# cp .env.production.example .env.production
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME=FluxAI
APP_ENV=production
APP_KEY=                                    # Generar con: php artisan key:generate
APP_DEBUG=false
APP_URL=https://app.fluxai.solutions

# Timezone
APP_TIMEZONE=America/Bogota

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=pgsql                               # Nombre del servicio en Docker
DB_PORT=5432
DB_DATABASE=fluxai
DB_USERNAME=sail
DB_PASSWORD=                                # CAMBIAR: Contraseña segura para producción

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_HOST=redis                            # Nombre del servicio en Docker
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Cache, Session & Queue
# -----------------------------------------------------------------------------
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

# -----------------------------------------------------------------------------
# Broadcasting (Laravel Echo Server)
# -----------------------------------------------------------------------------
BROADCAST_DRIVER=redis

# Pusher Configuration (para compatibilidad con Echo)
PUSHER_APP_ID=fluxai
PUSHER_APP_KEY=fluxai-key
PUSHER_APP_SECRET=fluxai-secret
PUSHER_APP_CLUSTER=mt1

# -----------------------------------------------------------------------------
# MQTT Configuration (Mosquitto)
# -----------------------------------------------------------------------------
MQTT_HOST=mosquitto                         # Nombre del servicio en Docker
MQTT_PORT=1883
MQTT_CLIENT_ID=fluxai-laravel
MQTT_AUTH_USERNAME=enertec
MQTT_AUTH_PASSWORD=                         # CAMBIAR: Misma contraseña configurada en Mosquitto

# Latencia y control de publicación
MQTT_PUBLISH_LATENCY=50
MQTT_SUBSCRIBE_LATENCY=50

# API Configuration
API_URL=https://app.fluxai.solutions
API_LATENCY=1000

# -----------------------------------------------------------------------------
# Mail Configuration
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org                  # O tu proveedor preferido
MAIL_PORT=587
MAIL_USERNAME=                              # COMPLETAR
MAIL_PASSWORD=                              # COMPLETAR
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@fluxai.solutions
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_LEVEL=error                             # En producción solo errores

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
DEBUGBAR_ENABLED=false

# JWT Authentication (para API)
JWT_SECRET=                                 # Generar con: php artisan jwt:secret

# Password para acceso a endpoints de firmware desde la app móvil
FIRMWARE_API_PASSWORD=                      # CAMBIAR: Password seguro para producción

# Filesystem
FILESYSTEM_DRIVER=local
